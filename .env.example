# ── Gemma 4 via Google AI Studio ──
# Get a free key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_ai_studio_key_here
GOOGLE_MODEL=gemma-4-31b-it
# Gemma 4 31B on the free tier is slow (~2-4 min/resume) — give it room.
GOOGLE_TIMEOUT=300
# Auto-retry transient free-tier 500s/timeouts.
LLM_MAX_RETRIES=4

# ── Server ──
# PORT=8000
